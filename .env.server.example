# ============================================
# Enterprise Regulation RAG Desktop - side-car 配置模板
# ============================================
# 复制为 .env.server 后填写。此文件独立于 .env，避免污染 RAG 核心配置
# （RAG 核心的 Settings 禁止额外键 extra="forbid"，混入 side-car 键会导致核心初始化失败）。
# side-car 的 config.py 会同时读取 .env（取 MODE 等共享项）与 .env.server。
# 注意：以下为占位/示例值，请勿提交真实密钥。

# --- JWT 鉴权 ---
# HS256 签名密钥（必填，禁止硬编码）。请生成一个高强度随机值，例如：
#   - PowerShell: [Convert]::ToBase64String((1..48|%{Get-Random -Max 256}))
#   - bash:       openssl rand -base64 48
#   - python:     python -c "import secrets;print(secrets.token_urlsafe(48))"
# 生产环境（ENVIRONMENT=production）下缺失此项将导致服务启动失败。
JWT_SECRET=change-me-to-a-strong-random-secret

# access token 过期时间（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=30
# refresh token 过期时间（天）
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- side-car 绑定地址（仅回环，禁止对外暴露） ---
SIDECAR_HOST=127.0.0.1
SIDECAR_PORT=8756

# --- 初始管理员播种（首次启动时创建） ---
# 首次启动若数据库无任何 admin，将用以下凭据创建初始管理员账户。
# 请设置一个强密码（满足后端密码策略：>=8 位且含字母与数字），切勿使用示例值。
BOOTSTRAP_ADMIN_USER=admin
BOOTSTRAP_ADMIN_PASSWORD=change-me-to-a-strong-admin-password

# --- 运行环境 ---
# development | production。生产环境强制要求 JWT_SECRET。
ENVIRONMENT=development

# --- 账户数据库（SQLite） ---
SQLITE_URL=sqlite:///./accounts.db
