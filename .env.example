# ============================================
# RAG2 - Self-RAG System Configuration
# ============================================

# --- Operating Mode ---
# Options: "CLOUD" or "LOCAL"
# CLOUD: Uses OpenAI GPT-4o (requires API key, faster, better reasoning)
# LOCAL: Uses Ollama local models (free, offline, requires local LLM installation)
MODE=CLOUD

# ============================================
# CLOUD MODE Configuration (OpenAI)
# ============================================
# Required when MODE=CLOUD
OPENAI_API_KEY=sk-your-openai-api-key-here

# ============================================
# LOCAL MODE Configuration (Ollama)
# ============================================
# Required when MODE=LOCAL
# Note: Ollama does NOT require an API key - it communicates via base_url only

# Ollama server endpoint (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Chat model for generation (e.g., llama3:8b, mistral:7b, qwen2:7b)
# Recommended: llama3:8b or mistral:7b for balanced performance
OLLAMA_CHAT_MODEL=llama3:8b

# Embedding model for vectorization (e.g., nomic-embed-text, mxbai-embed-large)
# Recommended: nomic-embed-text for good quality with reasonable size
OLLAMA_EMBED_MODEL=nomic-embed-text

# ============================================
# Vector Database Configuration
# ============================================
# ChromaDB storage path (relative to project root)
CHROMA_PERSIST_DIR=./chroma_db

# ============================================
# RAG System Parameters
# ============================================
# Maximum number of retrieval iterations (prevents infinite loops)
MAX_ITERATIONS=3

# Number of documents to retrieve per query
RETRIEVAL_K=4

# ============================================
# Example Configurations
# ============================================

# --- Cloud Mode (Default - Fast Development) ---
# MODE=CLOUD
# OPENAI_API_KEY=sk-...
# (Other Ollama settings ignored)

# --- Local Mode (Privacy & Cost-Free) ---
# MODE=LOCAL
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_CHAT_MODEL=llama3:8b
# OLLAMA_EMBED_MODEL=nomic-embed-text
# (OpenAI settings ignored)

# ============================================
# 桌面端 side-car 配置请见独立文件 .env.server.example
# ============================================
# 账户系统/JWT/管理员等 side-car 专属配置已移至 .env.server（模板：.env.server.example），
# 以免污染本文件被 RAG 核心读取（RAG 核心 Settings 禁止额外键）。
